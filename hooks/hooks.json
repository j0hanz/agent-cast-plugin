{
  "description": "Starts the AgentCast web UI automatically and logs Playwright MCP calls for the dashboard.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/start-web.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__playwright__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/log-mcp-call.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
